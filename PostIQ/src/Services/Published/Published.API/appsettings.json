{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BackgroundServices": {
    "RepoService": {
      "Enabled": true,
      "IntervalType": "Hour",
      "IntervalValue": 1,
      "QueueSize": 100
    },
    "RepoDetailsService": {
      "Enabled": true,
      "IntervalType": "Day",
      "IntervalValue": 1,
      "QueueSize": 50
    }
  }
}


