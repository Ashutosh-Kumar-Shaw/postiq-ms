{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DefaultConnection": "Server=(localdb)\\ProjectModels;Database=ProjectModels;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True;",
  "HttpClientSettings": {
    "Clients": {
      "PublishedApi": {
        "BaseAddress": "https://localhost:7155/api",
        "Timeout": "00:05:00",
        "BufferSize": 81920,
        "MaxResponseContentBufferSize": 0,
        "AutomaticDecompression": true,
        "DefaultHeaders": {
          "Accept": "application/json"
        }
      }
    }
  },
  "BackgroundJobs": {
    "Defaults": {
      "Enabled": true,
      "QueueSize": 100,
      "MaxConcurrentConsumers": 5,
      "FullMode": "Wait",
      "ProductionIntervalMs": 60000
    },
    "Jobs": {
      "PostSyncJob": {
        "Enabled": true,
        "Schedule": "10sec",
        "QueueSize": 50,
        "MaxConcurrentConsumers": 3,
        "FullMode": "Wait"
      }
    }
  }
}
